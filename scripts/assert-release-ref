#!/usr/bin/env bash
#
# assert-release-ref — refuse to tag a release that contains another line's work.
#
# THE invariant (and why it is NOT a plain ancestry test): a forward-merge of
# master into a 2.16 hotfix branch makes the 2.17 commits reachable from the
# hotfix tag, so "does the tag descend from the base?" still passes while the tag
# secretly drags 2.17 features into a 2.16.x stable. We instead require the tag's
# commit-set (everything it adds since the base) to be DISJOINT from the feature
# line's commit-set. Commit-set exclusivity, not ancestry.
#
# What the guard does NOT do: it compares commit SHAs, not content. A feature
# cherry-picked / squashed / reimplemented onto a 2.16 hotfix gets a fresh SHA,
# so the commit-sets stay disjoint and the tag passes. The guard catches the two
# MECHANICAL failure modes (a master forward-merge into the hotfix, and a 2.16
# tag sitting on a master commit); keeping 2.17 content out of 2.16 otherwise
# relies on the "cherry-pick onto master, never merge" rule in RELEASE_MANAGER.md.
#
# Checks per line (the line comes from scripts/release-line):
#   2.16.x : (a) tag descends from the base tag             else exit 1 (wrong root)
#            (b) commits(tag ^base) ∩ commits(feature ^base) == ∅   else exit 1
#   2.17+  : tag commit is contained in the feature ref     else exit 1
#   both   : a -dev.N/-beta.N (any -prerelease) suffix ⇔ the GitHub prerelease
#            flag, when that flag is known (RELEASE_PRERELEASE env)  else exit 1
# A real git error while testing any of the above is exit 2 (indeterminate).
#
# Usage:  assert-release-ref <tag>
#   env:  RELEASE_PRERELEASE=true|false   release.yml passes the release event's
#         prerelease flag; unset (a local pre-flight, before the release exists)
#         skips only the suffix↔flag check — the line invariant always runs.
#
# Exit:  0 pass · 1 violation · 2 indeterminate (missing refs / shallow / unparseable)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
RELEASE_LINE="$SCRIPT_DIR/release-line"
SELF="assert-release-ref"

violation()     { printf '%s: VIOLATION — %s\n'     "$SELF" "$1" >&2; exit 1; }
indeterminate() { printf '%s: INDETERMINATE — %s\n' "$SELF" "$1" >&2; exit 2; }

# ancestry <maybe-ancestor> <descendant> — classify `git merge-base --is-ancestor`
# honestly. Returns 0 (is ancestor) or 1 (definitively NOT an ancestor) so the
# caller chooses violation-vs-pass; ONLY a real git error (exit 128/other) is
# indeterminate. Collapsing "not an ancestor" (exit 1) into indeterminate would
# mask a wrong-line tag as "cannot evaluate" instead of failing it.
ancestry() {
  local rc=0
  git merge-base --is-ancestor "$1" "$2" || rc=$?
  case "$rc" in
    0) return 0 ;;
    1) return 1 ;;
    *) indeterminate "git merge-base --is-ancestor $1 $2 failed (rc=$rc)" ;;
  esac
}

usage() {
  cat <<'EOF'
assert-release-ref — guard that a release tag may only contain its own line's work.

Usage:  assert-release-ref <tag>
  env:  RELEASE_PRERELEASE=true|false  (suffix↔prerelease-flag check; unset = skip)

Exit:   0 pass · 1 violation · 2 indeterminate (missing refs / shallow / unparseable)
EOF
}

case "${1:-}" in
  -h|--help) usage; exit 0 ;;
  "")        indeterminate "missing <tag> (try --help)" ;;
esac
TAG="$1"

# Operate on the repo we were invoked in (cwd's toplevel), not the script's own
# repo — this both prevents a vacuous pass from the wrong cwd and lets the
# fixture tests run the real script against throwaway repos.
REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)" \
  || indeterminate "not inside a git work tree"
cd "$REPO_ROOT"

# The commit-set tests need full history.
if [ "$(git rev-parse --is-shallow-repository 2>/dev/null || echo false)" = "true" ]; then
  git fetch --unshallow --quiet 2>/dev/null \
    || indeterminate "shallow clone and 'git fetch --unshallow' failed — cannot evaluate history"
fi

# Classify + resolve config through the single source of truth.
if ! LINE="$("$RELEASE_LINE" "$TAG")"; then
  indeterminate "cannot classify '$TAG' (cause: no vX.Y.Z core; fix: use vX.Y.Z[-pre.N])"
fi
BASE_TAG="$("$RELEASE_LINE" --base-tag)"
FEATURE_REF="$("$RELEASE_LINE" --feature-ref)"

# Resolve the commit to be tagged. At pre-flight the tag may not exist yet, so
# fall back to HEAD (the commit about to be tagged).
if COMMIT="$(git rev-parse --verify --quiet "${TAG}^{commit}")"; then
  :
elif COMMIT="$(git rev-parse --verify --quiet 'HEAD^{commit}')"; then
  printf '%s: note — tag %s not created yet; evaluating HEAD %.9s\n' "$SELF" "$TAG" "$COMMIT" >&2
else
  indeterminate "cannot resolve a commit for '$TAG' or HEAD"
fi

git rev-parse --verify --quiet "${BASE_TAG}^{commit}" >/dev/null \
  || indeterminate "base tag $BASE_TAG not found (fix: git fetch origin --tags)"
git rev-parse --verify --quiet "${FEATURE_REF}^{commit}" >/dev/null \
  || indeterminate "feature ref $FEATURE_REF not found (fix: git fetch origin master)"

case "$LINE" in
  feature)
    ancestry "$COMMIT" "$FEATURE_REF" \
      || violation "$TAG ($LINE line) is not contained in $FEATURE_REF (cause: tagging a commit that isn't on the feature line; fix: tag a commit reachable from $FEATURE_REF)"
    ;;
  *)
    # Maintenance line (e.g. 2.16). Non-descent from the base is a definitive
    # VIOLATION (a stable patch built off the wrong root), not "indeterminate".
    ancestry "$BASE_TAG" "$COMMIT" \
      || violation "$TAG ($LINE line) does not descend from $BASE_TAG (cause: hotfix branched off the wrong root; fix: branch the hotfix from the newest v$LINE.x tag, never master)"
    # Commit-set exclusivity. Materialise each set with its OWN guard: a git
    # failure inside a <(…) process substitution does NOT fail the outer
    # assignment under `set -euo pipefail`, so `comm` would see empty input and
    # pass vacuously — a fail-OPEN that ships a contaminated tag. Capturing into
    # a variable makes a rev-list failure fail-CLOSED (indeterminate).
    tag_set="$(git rev-list "$COMMIT" "^$BASE_TAG")" \
      || indeterminate "cannot enumerate the commit-set of $TAG (unreadable history)"
    # An empty tag commit-set means the tag IS the base (a no-op retag): it adds
    # nothing, so it is trivially disjoint from the feature line — pass without
    # running comm (whose blank here-string inputs would be needless work).
    if [ -n "$tag_set" ]; then
      feature_set="$(git rev-list "$FEATURE_REF" "^$BASE_TAG")" \
        || indeterminate "cannot enumerate the commit-set of $FEATURE_REF (unreadable history)"
      overlap="$(comm -12 <(sort <<<"$tag_set") <(sort <<<"$feature_set"))"
      if [ -n "$overlap" ]; then
        first="${overlap%%$'\n'*}"
        violation "$TAG would ship feature-line work under a $LINE stable tag — e.g. commit ${first:0:9} is also on $FEATURE_REF (cause: master merged into the hotfix; fix: rebuild the hotfix as cherry-picks off $BASE_TAG, never merge master)"
      fi
    fi
    ;;
esac

# suffix ⇔ prerelease-flag consistency (D3).
case "$TAG" in *-*) expect_pre=true ;; *) expect_pre=false ;; esac
if [ -n "${RELEASE_PRERELEASE:-}" ]; then
  if [ "$RELEASE_PRERELEASE" != "$expect_pre" ]; then
    violation "$TAG prerelease-flag mismatch — the tag suffix implies prerelease=$expect_pre but the release is prerelease=$RELEASE_PRERELEASE (fix: a -dev.N/-beta.N tag must publish as a prerelease; a plain vX.Y.Z must not)"
  fi
else
  printf '%s: note — RELEASE_PRERELEASE unset; skipped the suffix↔prerelease-flag check\n' "$SELF" >&2
fi

printf '%s: OK — %s is a valid %s-line tag\n' "$SELF" "$TAG" "$LINE"
