#!/usr/bin/env bash

set -euo pipefail

cd "$(dirname "$0")/.."

if [[ -f ".context/ha-sync.env" ]]; then
    # shellcheck disable=SC1091
    source ".context/ha-sync.env"
fi

usage() {
    cat <<'EOF'
Usage: scripts/ha-sync [--frontend-only|--backend-only] [--no-build]

Sync the integration directly to a Home Assistant config directory over SSH,
bypassing release/HACS for day-to-day testing.

Configuration is read from environment variables or .context/ha-sync.env:

  HA_SSH_TARGET     required  e.g. root@your-ha-host
  HA_CONFIG_DIR     optional  defaults to /config
  HA_REMOVE_STALE   optional  set to 1 to auto-remove a leftover
                              custom_components/lightener dir (domain rename);
                              otherwise ha-sync only warns about the collision

Examples:
  cat > .context/ha-sync.env <<'EOF2'
  HA_SSH_TARGET=root@your-ha-host
  HA_CONFIG_DIR=/config
  EOF2

  scripts/ha-sync --frontend-only
  scripts/ha-sync

Notes:
  - Frontend syncs do not require a release cut and usually only need a browser refresh.
  - Python/backend changes still need a Home Assistant restart or equivalent manual reload
    to load new module code. This script never restarts Home Assistant.
EOF
}

MODE="all"
BUILD_FRONTEND=1

while [[ $# -gt 0 ]]; do
    case "$1" in
        --frontend-only)
            MODE="frontend"
            shift
            ;;
        --backend-only)
            MODE="backend"
            shift
            ;;
        --no-build)
            BUILD_FRONTEND=0
            shift
            ;;
        -h|--help|help)
            usage
            exit 0
            ;;
        *)
            echo "[ha-sync] Unknown option: $1" >&2
            usage >&2
            exit 1
            ;;
    esac
done

if [[ -z "${HA_SSH_TARGET:-}" ]]; then
    echo "[ha-sync] HA_SSH_TARGET is required. Set it in the environment or .context/ha-sync.env." >&2
    exit 1
fi

HA_CONFIG_DIR=${HA_CONFIG_DIR:-/config}
REMOTE_COMPONENT_DIR="${HA_CONFIG_DIR}/custom_components/lightener_studio"
SSH_DESTINATION="${HA_SSH_TARGET}:${REMOTE_COMPONENT_DIR}/"
COMMON_RSYNC_ARGS=(
    -az
    --delete
    --exclude '__pycache__/'
    --exclude '*.pyc'
    --exclude '.DS_Store'
)

if [[ "${MODE}" != "backend" ]]; then
    echo "[ha-sync] Syncing CARD_VERSION..."
    python3 scripts/sync-version
fi

if [[ "${BUILD_FRONTEND}" -eq 1 && "${MODE}" != "backend" ]]; then
    echo "[ha-sync] Building frontend bundle..."
    (
        cd js
        npm run build
    )
fi

echo "[ha-sync] Ensuring remote destination exists..."
if [[ "${MODE}" == "frontend" ]]; then
    ssh "${HA_SSH_TARGET}" "mkdir -p '${REMOTE_COMPONENT_DIR}/frontend'"
else
    ssh "${HA_SSH_TARGET}" "mkdir -p '${REMOTE_COMPONENT_DIR}'"
fi

# Domain-rename safety: a leftover custom_components/lightener dir collides with
# lightener_studio (both register the same panel, websocket commands, and card
# element) and breaks Home Assistant on restart. Detect it; remove it only when
# explicitly opted in via HA_REMOVE_STALE=1.
REMOTE_OLD_DIR="${HA_CONFIG_DIR}/custom_components/lightener"
if ssh "${HA_SSH_TARGET}" "test -d '${REMOTE_OLD_DIR}'"; then
    if [[ "${HA_REMOVE_STALE:-0}" == "1" ]]; then
        echo "[ha-sync] Removing stale old integration dir (HA_REMOVE_STALE=1): ${REMOTE_OLD_DIR}"
        ssh "${HA_SSH_TARGET}" "rm -rf -- '${REMOTE_OLD_DIR}'"
    else
        echo "[ha-sync] WARNING: stale old integration dir present on the remote:" >&2
        echo "[ha-sync]   ${REMOTE_OLD_DIR}" >&2
        echo "[ha-sync]   It collides with lightener_studio and will break HA on restart." >&2
        echo "[ha-sync]   Remove it (with HA stopped), then run the domain migrator. Either:" >&2
        echo "[ha-sync]     ssh ${HA_SSH_TARGET} \"rm -rf '${REMOTE_OLD_DIR}'\"" >&2
        echo "[ha-sync]   or re-run ha-sync with HA_REMOVE_STALE=1 to remove it automatically." >&2
    fi
fi

case "${MODE}" in
    frontend)
        echo "[ha-sync] Syncing frontend assets to ${SSH_DESTINATION}frontend/ ..."
        rsync "${COMMON_RSYNC_ARGS[@]}" \
            custom_components/lightener_studio/frontend/ \
            "${HA_SSH_TARGET}:${REMOTE_COMPONENT_DIR}/frontend/"
        ;;
    backend)
        echo "[ha-sync] Syncing backend integration files to ${SSH_DESTINATION} ..."
        rsync "${COMMON_RSYNC_ARGS[@]}" \
            --exclude 'frontend/' \
            custom_components/lightener_studio/ \
            "${SSH_DESTINATION}"
        ;;
    all)
        echo "[ha-sync] Syncing full integration to ${SSH_DESTINATION} ..."
        rsync "${COMMON_RSYNC_ARGS[@]}" \
            custom_components/lightener_studio/ \
            "${SSH_DESTINATION}"
        ;;
esac

echo ""
echo "[ha-sync] Sync complete"
echo "  Target: ${HA_SSH_TARGET}"
echo "  Config: ${HA_CONFIG_DIR}"

if [[ "${MODE}" != "backend" ]]; then
    echo "  Frontend next step: hard-refresh the HA page or revisit /lightener/lightener-curve-card.js"
fi

if [[ "${MODE}" != "frontend" ]]; then
    echo "  Backend next step: restart or manually reload Home Assistant if you changed Python code"
    echo "  Safety: this script never restarts HA for you"
fi
