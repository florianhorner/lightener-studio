#!/usr/bin/env python3
"""Sync CARD_VERSION in lightener-panel.js to match manifest.json version.

Run before any deploy or release so the panel always loads the correct card version.
"""

import json
import re
import sys
from pathlib import Path

if len(sys.argv) > 1 and sys.argv[1] in ("-h", "--help", "help"):
    print(
        "Usage: scripts/sync-version\n\n"
        "Syncs CARD_VERSION in lightener-panel.js and js/src/lightener-curve-card.ts\n"
        "to match the version in custom_components/lightener_studio/manifest.json.\n\n"
        "Run after bumping manifest.json, or let scripts/ha-sync and the release\n"
        "workflow call it automatically."
    )
    sys.exit(0)

ROOT = Path(__file__).parent.parent
MANIFEST = ROOT / "custom_components/lightener_studio/manifest.json"
PANEL_JS = ROOT / "custom_components/lightener_studio/frontend/lightener-panel.js"
CARD_TS = ROOT / "js/src/lightener-curve-card.ts"
SEMVER_RE = re.compile(r"[0-9]+\.[0-9]+\.[0-9]+(?:-[A-Za-z0-9.]+)?(?:\+[A-Za-z0-9.]+)?")

try:
    _manifest = json.loads(MANIFEST.read_text())
except Exception as e:
    print(f"[sync-version] ERROR: cannot read manifest.json: {e}", file=sys.stderr)
    sys.exit(1)

if "version" not in _manifest:
    print(
        '[sync-version] ERROR: "version" key missing from manifest.json',
        file=sys.stderr,
    )
    sys.exit(1)

version = _manifest["version"]

if not isinstance(version, str) or SEMVER_RE.fullmatch(version) is None:
    print(
        f"[sync-version] ERROR: version {version!r} is not a valid semver string",
        file=sys.stderr,
    )
    sys.exit(1)

updates = [
    (PANEL_JS, r'^const CARD_VERSION = ".*";'),
    (CARD_TS, r"^const CARD_VERSION = '.*';"),
]
changed = False

for path, pattern in updates:
    content = path.read_text()
    updated, count = re.subn(
        pattern,
        (
            f'const CARD_VERSION = "{version}";'
            if path.suffix == ".js"
            else f"const CARD_VERSION = '{version}';"
        ),
        content,
        flags=re.MULTILINE,
    )

    if count != 1:
        print(
            f"[sync-version] ERROR: expected exactly one CARD_VERSION constant in {path.name}"
            f" (found {count})",
            file=sys.stderr,
        )
        sys.exit(1)

    if content == updated:
        continue

    changed = True
    tmp = path.with_suffix(path.suffix + ".tmp")
    try:
        tmp.write_text(updated)
        tmp.replace(path)
    except Exception:
        tmp.unlink(missing_ok=True)
        raise

if changed:
    print(f"[sync-version] CARD_VERSION → {version!r}")
else:
    print(f"[sync-version] CARD_VERSION already at {version!r}")
