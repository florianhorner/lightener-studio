#!/usr/bin/env bash

set -euo pipefail

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" || "${1:-}" == "help" ]]; then
    cat <<'EOF'
Usage: scripts/setup-python

Create the local Python 3.13 virtualenv at .venv, install backend
dependencies, write .env.workspace, and install pre-commit hooks.

Run once after cloning, or whenever Python requirements files change.
EOF
    exit 0
fi

cd "$(dirname "$0")/.."

PY_VERSION=${PY_VERSION:-3.13.2}

export PATH="$HOME/.local/bin:$PATH"
if [[ -d "$HOME/.cargo/bin" ]]; then
    export PATH="$HOME/.cargo/bin:$PATH"
fi

echo "[setup-python] Ensuring uv is available..."
if ! command -v uv >/dev/null 2>&1; then
    curl -fsSL https://astral.sh/uv/install.sh | sh
fi

echo "[setup-python] Ensuring Python ${PY_VERSION} is available..."
uv python install "${PY_VERSION}"

RECREATE_VENV=0
if [[ ! -x ".venv/bin/python" ]]; then
    RECREATE_VENV=1
else
    CURRENT_PY_VERSION=$(.venv/bin/python -c 'import platform; print(platform.python_version())' || echo "")
    if [[ "${CURRENT_PY_VERSION}" != "${PY_VERSION}" ]]; then
        RECREATE_VENV=1
    fi
fi

if [[ ${RECREATE_VENV} -eq 1 ]]; then
    echo "[setup-python] Creating virtual environment at .venv with Python ${PY_VERSION}..."
    uv venv --clear --python "${PY_VERSION}" .venv
else
    echo "[setup-python] Reusing existing virtual environment (.venv) with Python ${CURRENT_PY_VERSION}."
fi

echo "[setup-python] Installing dependencies..."
# Order is load-bearing: requirements-ha-test.txt pins pytest==9.0.0 via the HA
# test stack; requirements.txt installs second to override pytest to its own pin.
uv pip install --python .venv/bin/python -r requirements-ha-test.txt
uv pip install --python .venv/bin/python -r requirements.txt

# Fail loud if the override didn't take (e.g. the two installs were reordered).
expected_pytest="$(grep -oE '^pytest==[0-9.]+' requirements.txt | cut -d= -f3 || true)"
actual_pytest="$(.venv/bin/python -c 'import pytest; print(pytest.__version__)')"
if [[ -z "${expected_pytest}" ]]; then
    echo "[setup-python] ERROR: no pinned 'pytest==' found in requirements.txt." >&2
    exit 1
fi
if [[ "${expected_pytest}" != "${actual_pytest}" ]]; then
    echo "[setup-python] ERROR: pytest ${actual_pytest} installed but requirements.txt pins ${expected_pytest} (install-order regression)." >&2
    exit 1
fi

cat > .env.workspace <<'EOF'
# Source this in the workspace terminal for a ready dev environment.
# IMPORTANT: source from the repo root — uses relative paths.
#   cd /path/to/lightener-studio && source .env.workspace
export LIGHTENER_REPO_ROOT="${PWD}"
source .venv/bin/activate
# Avoid leading colon when PYTHONPATH is unset (would add "" = cwd to search path).
export PYTHONPATH="${PYTHONPATH:+$PYTHONPATH:}${LIGHTENER_REPO_ROOT}/custom_components"
# Route accidental bare `pytest` calls through the repo-managed Home Assistant
# test environment instead of whatever global pytest happens to be on PATH.
pytest() {
    "${LIGHTENER_REPO_ROOT}/.venv/bin/python" -m pytest "$@"
}
echo "Lightener dev env active — tests: scripts/test-python or bare pytest, HA: scripts/develop"
EOF

if [[ -x ".venv/bin/pre-commit" ]]; then
    echo "[setup-python] Installing pre-commit hooks..."
    .venv/bin/pre-commit install --install-hooks || true
fi

echo ""
echo "[setup-python] Backend environment ready"
echo "  Activate shell:   source .env.workspace"
echo "  Fast local loop:  scripts/test-fast"
echo "  Test backend:     scripts/test-python"
echo "  Run HA locally:   scripts/develop"
